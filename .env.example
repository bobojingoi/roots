# Credențiale Smoobu (autentificare HMAC) — Smoobu: Settings → Advanced → API Keys → Create.
# La creare primești un „Label" (cheia) și un „Secret" (afișat o singură dată).
# Copiază acest fișier în `.env` și completează. `.env` este ignorat de git.
# Pe Vercel: adaugă ambele în Project → Settings → Environment Variables (aceleași nume).
SMOOBU_API_KEY=
SMOOBU_API_SECRET=

# Rezervări reale în Smoobu prin /api/book. Lasă gol/false = dry-run (nu creează rezervări).
# Pune „true" doar când vrei ca /api/book să creeze rezervări REALE în contul Smoobu.
BOOKING_LIVE=

# Email de confirmare (Resend — resend.com). Fără acestea, rezervarea merge dar nu se trimite email.
# RESEND_API_KEY = cheia din Resend. EMAIL_FROM = expeditor de pe un domeniu verificat în Resend
# (ex. "ROOTS Villas <rezervari@panocube.ro>"). EMAIL_TO = adresa ta, pt copie la fiecare rezervare.
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_TO=

# ID-urile de apartament NU stau aici — se setează per vilă din panoul Admin
# (câmpul „ID apartament Smoobu"), pentru fiecare vilă în parte.
