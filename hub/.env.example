# Postgres (Supabase — session pooler, port 5432)
DATABASE_URL=
# Secret pentru semnarea cookie-urilor de autentificare (64 hex)
AUTH_SECRET=
# Smoobu (Faza 2 — sync rezervări)
SMOOBU_API_KEY=
SMOOBU_API_SECRET=
# Supabase Storage (S3) — pentru Galerie media
S3_BUCKET=media
S3_ENDPOINT=
S3_REGION=eu-central-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Seed inițial (opțional)
SEED_OWNER_EMAIL=
SEED_OWNER_PASSWORD=
